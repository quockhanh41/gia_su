# Cấu hình Email - SendGrid (Khuyến nghị cho Render.com)
# Đăng ký miễn phí: https://signup.sendgrid.com (100 emails/ngày)
# Lấy API Key: Settings → API Keys → Create API Key
# Note: EMAIL_USER phải được verify trong SendGrid (Sender Authentication)
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here

# Cấu hình Email - Gmail SMTP (Fallback, có thể bị timeout trên Render)
# Lấy App Password từ: https://myaccount.google.com/apppasswords
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your_16_character_app_password

# Google Maps API Key
# Lấy từ: https://console.cloud.google.com/google/maps-apis
# Cần enable: Distance Matrix API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
